<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">


    <!-- ========================================================= -->
    <!-- TOP APP BAR                                               -->
    <!-- ========================================================= -->

    <LinearLayout
        android:id="@+id/topAppBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="10dp"
            android:src="@drawable/ic_back_arrow"
            app:tint="#111827" />


        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Verify Identity"
            android:textColor="#111827"
            android:textSize="19sp"
            android:textStyle="bold" />


        <Space
            android:layout_width="44dp"
            android:layout_height="44dp" />

    </LinearLayout>


    <!-- ========================================================= -->
    <!-- CONTENT                                                   -->
    <!-- ========================================================= -->

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topAppBar">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="42dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">


            <!-- ================================================= -->
            <!-- SECURITY ICON                                     -->
            <!-- ================================================= -->

            <FrameLayout
                android:layout_width="104dp"
                android:layout_height="104dp"
                android:background="@drawable/badge_green">

                <FrameLayout
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_security_inner">

                    <ImageView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_gravity="center"
                        android:contentDescription="Security"
                        app:tint="#22C55E"
                        android:src="@drawable/lock"
                        />

                </FrameLayout>

            </FrameLayout>


            <!-- ================================================= -->
            <!-- TITLE                                             -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:text="Confirm It's You"
                android:textColor="#111827"
                android:textSize="25sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- DESCRIPTION                                       -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="20dp"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:text="For your security, enter your current password before setting up two-factor authentication."
                android:textColor="#6B7280"
                android:textSize="14sp" />


            <!-- ================================================= -->
            <!-- PASSWORD LABEL                                    -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="42dp"
                android:text="Current Password"
                android:textColor="#111827"
                android:textSize="14sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- PASSWORD FIELD                                    -->
            <!-- ================================================= -->

            <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/passwordInputLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:boxBackgroundColor="#FFFFFF"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxStrokeColor="#22C55E"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:startIconDrawable="@drawable/ic_lock"
            app:startIconTint="#6B7280"
            app:endIconMode="password_toggle"
            app:endIconTint="#6B7280">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCurrentPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="50dp"
                android:hint="Enter your current password"
                android:inputType="textPassword"
                android:minHeight="58dp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:textSize="14sp"/>

        </com.google.android.material.textfield.TextInputLayout>


            <!-- ================================================= -->
            <!-- SECURITY INFORMATION                              -->
            <!-- ================================================= -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#F0FDF4"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#DCFCE7"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <FrameLayout
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_notification_icon">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:contentDescription="Secure"
                            android:src="@drawable/ic_lock"
                            app:tint="#22C55E" />

                    </FrameLayout>


                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:lineSpacingExtra="2dp"
                        android:text="Your password is only used to confirm your identity and keep your account secure."
                        android:textColor="#4B5563"
                        android:textSize="13sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


            <!-- ================================================= -->
            <!-- CONTINUE BUTTON                                   -->
            <!-- ================================================= -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerifyAndContinue"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="34dp"
                android:text="Verify &amp; Continue"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#22C55E"
                app:cornerRadius="16dp" />


            <!-- ================================================= -->
            <!-- CANCEL                                            -->
            <!-- ================================================= -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="12dp"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="#111827"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:strokeColor="#D1D5DB"
                app:strokeWidth="1dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>