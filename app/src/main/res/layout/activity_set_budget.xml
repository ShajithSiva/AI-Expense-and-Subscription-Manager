<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:background="#FFFFFF">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="‹"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="#111827" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="Add Budget"
            android:textSize="21sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:paddingStart="8dp" />

        <TextView
            android:id="@+id/btnSaveTop"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Save"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#9CA3AF" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#9CA3AF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="64dp"
            android:paddingBottom="30dp">

            <!-- PERIOD AND START DATE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PERIOD"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#374151" />

                    <TextView
                        android:id="@+id/tvBudgetPeriod"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="Monthly        ˅"
                        android:textSize="16sp"
                        android:textColor="#111827"
                        android:background="@drawable/bg_input_rounded" />
                </LinearLayout>

                <Space
                    android:layout_width="16dp"
                    android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="START DATE"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#374151" />

                    <LinearLayout
                        android:id="@+id/tvStartDate"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="@drawable/bg_input_rounded">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/calendar"
                            android:scaleType="fitCenter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="Today"
                            android:textSize="16sp"
                            android:textColor="#111827" />

                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- TOTAL AMOUNT -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL BUDGET AMOUNT"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#374151"
                android:layout_marginTop="40dp" />

            <EditText
                android:id="@+id/etTotalBudgetAmount"
                android:layout_width="match_parent"
                android:layout_height="68dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input_rounded"
                android:hint="Rs   0.00"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:textColorHint="#D1D5DB"
                android:inputType="numberDecimal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enter your total monthly spending limit across all accounts."
                android:textSize="14sp"
                android:textColor="#374151"
                android:layout_marginTop="12dp" />

            <!-- CATEGORY ALLOCATION TITLE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="38dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CATEGORY ALLOCATION"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:textColor="#374151" />

                <TextView
                    android:id="@+id/btnAddCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+   Add Category"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#111827" />
            </LinearLayout>

            <!-- CATEGORY 1 -->
            <LinearLayout
                android:id="@+id/categoryRowGroceries"
                android:layout_width="match_parent"
                android:layout_height="102dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_category_box">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.45"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Category"
                        android:textSize="13sp"
                        android:textColor="#374151" />

                    <TextView
                        android:id="@+id/tvCategoryGroceries"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="Groceries &amp;\nFood        ˅"
                        android:textSize="16sp"
                        android:textColor="#111827"
                        android:background="@drawable/bg_input_rounded" />
                </LinearLayout>

                <Space
                    android:layout_width="16dp"
                    android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Limit"
                        android:textSize="13sp"
                        android:textColor="#374151" />

                    <EditText
                        android:id="@+id/etGroceriesLimit"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_rounded"
                        android:text="Rs 15000"
                        android:textSize="16sp"
                        android:textColor="#111827"
                        android:inputType="number"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btnDeleteGroceries"
                    android:layout_width="40dp"
                    android:layout_height="50dp"
                    android:layout_marginTop="26dp"
                    android:gravity="center"
                    android:text="⌫"
                    android:textSize="24sp"
                    android:textColor="#EF4444" />
            </LinearLayout>

            <!-- CATEGORY 2 -->
            <LinearLayout
                android:id="@+id/categoryRowRentUtilities"
                android:layout_width="match_parent"
                android:layout_height="102dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_category_box">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.45"
                    android:orientation="vertical">

                    <TextView
                        android:text="Category"
                        android:textSize="13sp"
                        android:textColor="#374151"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/tvCategoryRentUtilities"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="Rent &amp; Utilities        ˅"
                        android:textSize="16sp"
                        android:textColor="#111827"
                        android:background="@drawable/bg_input_rounded" />
                </LinearLayout>

                <Space
                    android:layout_width="16dp"
                    android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:text="Limit"
                        android:textSize="13sp"
                        android:textColor="#374151"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/etRentUtilitiesLimit"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_rounded"
                        android:text="Rs 25000"
                        android:textSize="16sp"
                        android:textColor="#111827"
                        android:inputType="number"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btnDeleteRentUtilities"
                    android:layout_width="40dp"
                    android:layout_height="50dp"
                    android:layout_marginTop="26dp"
                    android:gravity="center"
                    android:text="⌫"
                    android:textSize="24sp"
                    android:textColor="#EF4444" />
            </LinearLayout>

            <!-- CATEGORY 3 -->
            <LinearLayout
                android:id="@+id/categoryRowEntertainment"
                android:layout_width="match_parent"
                android:layout_height="102dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_category_box">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.45"
                    android:orientation="vertical">

                    <TextView
                        android:text="Category"
                        android:textSize="13sp"
                        android:textColor="#374151"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/tvCategoryEntertainment"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="Entertainment        ˅"
                        android:textSize="16sp"
                        android:textColor="#111827"
                        android:background="@drawable/bg_input_rounded" />
                </LinearLayout>

                <Space
                    android:layout_width="16dp"
                    android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:text="Limit"
                        android:textSize="13sp"
                        android:textColor="#374151"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/etEntertainmentLimit"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_rounded"
                        android:text="Rs 8000"
                        android:textSize="16sp"
                        android:textColor="#111827"
                        android:inputType="number"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btnDeleteEntertainment"
                    android:layout_width="40dp"
                    android:layout_height="50dp"
                    android:layout_marginTop="26dp"
                    android:gravity="center"
                    android:text="⌫"
                    android:textSize="24sp"
                    android:textColor="#EF4444" />
            </LinearLayout>

            <!-- ERROR MESSAGE -->
            <LinearLayout
                android:id="@+id/layoutBudgetError"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_error_box">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="!"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#EF4444" />

                <TextView
                    android:id="@+id/tvBudgetError"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Category limits exceed total budget."
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#DC2626" />
            </LinearLayout>

            <!-- BUDGET SCOPE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BUDGET SCOPE"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:textColor="#374151"
                android:layout_marginTop="36dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:orientation="horizontal"
                android:padding="6dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_segment_container">

                <TextView
                    android:id="@+id/btnPersonalScope"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="♙  Personal"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:background="@drawable/bg_segment_selected" />

                <TextView
                    android:id="@+id/btnFamilySharedScope"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="♙  Family Shared"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#374151" />
            </LinearLayout>

            <!-- SUGGESTION BOX -->
            <LinearLayout
                android:id="@+id/layoutSuggestion"
                android:layout_width="match_parent"
                android:layout_height="136dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="18dp"
                android:layout_marginTop="34dp"
                android:background="@drawable/bg_suggestion_box">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:text="!"
                    android:textSize="24sp"
                    android:textColor="#22C55E"
                    android:background="@drawable/bg_icon_circle" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:id="@+id/tvBudgetSuggestion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Based on your past spending, suggested monthly budget is Rs 45,000."
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#14532D" />

                    <TextView
                        android:id="@+id/btnApplySuggestion"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:text="Apply Suggestion"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_green_button" />
                </LinearLayout>
            </LinearLayout>

            <!-- BUTTONS -->
            <TextView
                android:id="@+id/btnCreateBudget"
                android:layout_width="match_parent"
                android:layout_height="62dp"
                android:gravity="center"
                android:text="Create Budget"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="56dp"
                android:background="@drawable/bg_green_button" />

            <TextView
                android:id="@+id/btnCancel"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:gravity="center"
                android:text="Cancel"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#4B5563"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_gray_button" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>