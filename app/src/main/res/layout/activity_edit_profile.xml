<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FA">

    <!-- ========================================================= -->
    <!-- HEADER                                                    -->
    <!-- ========================================================= -->

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back Button -->

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="13dp"
            android:src="@drawable/ic_back_arrow"
            app:tint="#111827" />

        <!-- Screen Title -->

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Edit Profile"
            android:textColor="#111827"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>


    <!-- ========================================================= -->
    <!-- HEADER DIVIDER                                            -->
    <!-- ========================================================= -->

    <View
        android:id="@+id/headerDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E5E7EB"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout" />


    <!-- ========================================================= -->
    <!-- SCROLLABLE CONTENT                                        -->
    <!-- ========================================================= -->

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerDivider">

        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">


            <!-- ================================================= -->
            <!-- PROFILE PHOTO                                     -->
            <!-- ================================================= -->

            <FrameLayout
                android:id="@+id/profileSection"
                android:layout_width="match_parent"
                android:layout_height="140dp">


                <!-- Profile Image Container -->

                <FrameLayout
                    android:id="@+id/profileImageContainer"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center_horizontal">


                    <!-- Profile Background Circle -->

                    <View
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:background="@drawable/bg_profile_avatar" />


                    <!-- Profile Image -->

                    <ImageView
                        android:id="@+id/imgProfile"
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:layout_gravity="center"
                        android:contentDescription="Profile Photo"
                        android:scaleType="centerInside"
                        android:src="@drawable/profile"
                        app:tint="#FFFFFF" />


                    <!-- Camera Button -->

                    <FrameLayout
                        android:id="@+id/btnChangePhoto"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_camera_circle"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:padding="11dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="Change Profile Photo"
                            android:scaleType="centerInside"
                            android:src="@drawable/camera"
                            app:tint="#FFFFFF" />

                    </FrameLayout>

                </FrameLayout>

            </FrameLayout>


            <!-- Change Photo Text -->

            <TextView
                android:id="@+id/tvChangePhotoLabel"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_gravity="center_horizontal"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Change Photo"
                android:textColor="#22C55E"
                android:textSize="15sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- PERSONAL INFORMATION TITLE                        -->
            <!-- ================================================= -->

            <TextView
                android:id="@+id/tvPersonalInformationTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="PERSONAL INFORMATION"
                android:textColor="#6B7280"
                android:textSize="13sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- PERSONAL INFORMATION CARD                         -->
            <!-- ================================================= -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/personalInformationCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeColor="#EEEEEE"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp">


                    <!-- ================================================= -->
                    <!-- FULL NAME                                         -->
                    <!-- ================================================= -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="92dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <!-- Full Name Icon Background -->

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_field_icon">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:contentDescription="Full Name"
                                android:src="@drawable/profile"
                                app:tint="#22C55E" />

                        </FrameLayout>


                        <!-- Full Name Text Section -->

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Full Name"
                                android:textColor="#6B7280"
                                android:textSize="13sp" />

                            <EditText
                                android:id="@+id/etFullName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:background="@null"
                                android:hint="Enter your full name"
                                android:imeOptions="actionNext"
                                android:inputType="textPersonName"
                                android:maxLines="1"
                                android:paddingStart="0dp"
                                android:paddingTop="2dp"
                                android:paddingEnd="0dp"
                                android:paddingBottom="2dp"
                                android:text="TASK B"
                                android:textColor="#111827"
                                android:textColorHint="#9CA3AF"
                                android:textSize="17sp" />

                        </LinearLayout>

                    </LinearLayout>


                    <!-- Divider -->

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="64dp"
                        android:background="#E5E7EB" />


                    <!-- ================================================= -->
                    <!-- EMAIL ADDRESS                                     -->
                    <!-- ================================================= -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="92dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <!-- Email Icon Background -->

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_field_icon">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:contentDescription="Email Address"
                                android:src="@drawable/ic_email"
                                app:tint="#22C55E" />

                        </FrameLayout>


                        <!-- Email Text Section -->

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Email Address"
                                android:textColor="#6B7280"
                                android:textSize="13sp" />

                            <EditText
                                android:id="@+id/etEmail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:background="@null"
                                android:hint="Enter your email address"
                                android:imeOptions="actionNext"
                                android:inputType="textEmailAddress"
                                android:maxLines="1"
                                android:paddingStart="0dp"
                                android:paddingTop="2dp"
                                android:paddingEnd="0dp"
                                android:paddingBottom="2dp"
                                android:text="task_b@expensevault.com"
                                android:textColor="#111827"
                                android:textColorHint="#9CA3AF"
                                android:textSize="17sp" />

                        </LinearLayout>

                    </LinearLayout>


                    <!-- Divider -->

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="64dp"
                        android:background="#E5E7EB" />


                    <!-- ================================================= -->
                    <!-- PHONE NUMBER                                      -->
                    <!-- ================================================= -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="92dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <!-- Phone Icon Background -->

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_field_icon">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:contentDescription="Phone Number"
                                android:src="@drawable/ic_phone"
                                app:tint="#22C55E" />

                        </FrameLayout>


                        <!-- Phone Text Section -->

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phone Number"
                                android:textColor="#6B7280"
                                android:textSize="13sp" />

                            <EditText
                                android:id="@+id/etPhone"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:background="@null"
                                android:hint="Enter your phone number"
                                android:imeOptions="actionDone"
                                android:inputType="phone"
                                android:maxLength="15"
                                android:maxLines="1"
                                android:paddingStart="0dp"
                                android:paddingTop="2dp"
                                android:paddingEnd="0dp"
                                android:paddingBottom="2dp"
                                android:textColor="#111827"
                                android:textColorHint="#9CA3AF"
                                android:textSize="17sp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


            <!-- ================================================= -->
            <!-- ADDITIONAL DETAILS TITLE                          -->
            <!-- ================================================= -->

            <TextView
                android:id="@+id/tvAdditionalDetailsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="ADDITIONAL DETAILS"
                android:textColor="#6B7280"
                android:textSize="13sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- ADDITIONAL DETAILS CARD                           -->
            <!-- ================================================= -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/additionalDetailsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeColor="#EEEEEE"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp">


                    <!-- ================================================= -->
                    <!-- DATE OF BIRTH                                     -->
                    <!-- ================================================= -->

                    <LinearLayout
                        android:id="@+id/layoutDob"
                        android:layout_width="match_parent"
                        android:layout_height="92dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <!-- Calendar Icon Background -->

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_field_icon">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:contentDescription="Date of Birth"
                                android:src="@drawable/calender"
                                app:tint="#22C55E" />

                        </FrameLayout>


                        <!-- Date Text Section -->

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Date of Birth"
                                android:textColor="#6B7280"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tvDob"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Select date of birth"
                                android:textColor="#9CA3AF"
                                android:textSize="17sp" />

                        </LinearLayout>


                        <!-- Arrow Icon -->

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Select Date of Birth"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#6B7280" />

                    </LinearLayout>


                    <!-- Divider -->

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="64dp"
                        android:background="#E5E7EB" />


                    <!-- ================================================= -->
                    <!-- GENDER                                            -->
                    <!-- ================================================= -->

                    <LinearLayout
                        android:id="@+id/layoutGender"
                        android:layout_width="match_parent"
                        android:layout_height="92dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <!-- Gender Icon Background -->

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_field_icon">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:contentDescription="Gender"
                                android:src="@drawable/profile"
                                app:tint="#22C55E" />

                        </FrameLayout>


                        <!-- Gender Text Section -->

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Gender"
                                android:textColor="#6B7280"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tvGender"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Select gender"
                                android:textColor="#9CA3AF"
                                android:textSize="17sp" />

                        </LinearLayout>


                        <!-- Arrow Icon -->

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Select Gender"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#6B7280" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


            <!-- ================================================= -->
            <!-- SAVE CHANGES BUTTON                               -->
            <!-- ================================================= -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveChanges"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="32dp"
                android:text="Save Changes"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#22C55E"
                app:cornerRadius="16dp" />


            <!-- ================================================= -->
            <!-- CANCEL BUTTON                                     -->
            <!-- ================================================= -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="12dp"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="#374151"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:strokeColor="#D1D5DB"
                app:strokeWidth="1dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>