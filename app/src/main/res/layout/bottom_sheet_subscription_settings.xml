<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/subscriptionSettingsBottomSheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_notification_bottom_sheet"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">


        <!-- ===================================================== -->
        <!-- DRAG HANDLE                                           -->
        <!-- ===================================================== -->

        <View
            android:layout_width="48dp"
            android:layout_height="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_bottom_sheet_handle" />


        <!-- ===================================================== -->
        <!-- TITLE                                                 -->
        <!-- ===================================================== -->

        <TextView
            android:id="@+id/tvSubscriptionSettingsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Subscription Settings"
            android:textColor="#111827"
            android:textSize="22sp"
            android:textStyle="bold" />


        <!-- ===================================================== -->
        <!-- DESCRIPTION                                           -->
        <!-- ===================================================== -->

        <TextView
            android:id="@+id/tvSubscriptionSettingsDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="24dp"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:text="Customize how subscriptions are detected, tracked and monitored."
            android:textColor="#6B7280"
            android:textSize="14sp" />


        <!-- ===================================================== -->
        <!-- SETTINGS CONTAINER                                    -->
        <!-- ===================================================== -->

        <LinearLayout
            android:id="@+id/subscriptionSettingsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">


            <!-- ================================================= -->
            <!-- RENEWAL REMINDERS                                 -->
            <!-- ================================================= -->

            <LinearLayout
                android:id="@+id/layoutRenewalReminders"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">


                <!-- Icon Container -->

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_notification_icon">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:contentDescription="Renewal Reminders"
                        android:src="@drawable/ic_refresh"
                        app:tint="#22C55E" />

                </FrameLayout>


                <!-- Text Container -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Renewal Reminders"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Get notified before renewals"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                </LinearLayout>


                <!-- Switch -->

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchRenewalReminders"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="@color/notification_switch_thumb"
                    app:trackTint="@color/notification_switch_track" />

            </LinearLayout>


            <!-- ================================================= -->
            <!-- REMINDER TIME                                     -->
            <!-- ================================================= -->

            <LinearLayout
                android:id="@+id/layoutReminderTime"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="68dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:layout_weight="1"
                    android:text="Reminder Time"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold" />


                <!-- Reminder Selector -->

                <TextView
                    android:id="@+id/tvReminderTime"
                    android:layout_width="150dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_budget_setting_input"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="3 days before"
                    android:textColor="#111827"
                    android:textSize="14sp" />

            </LinearLayout>


            <!-- Divider -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB" />


            <!-- ================================================= -->
            <!-- PRICE CHANGE ALERTS                               -->
            <!-- ================================================= -->

            <LinearLayout
                android:id="@+id/layoutPriceChangeAlerts"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">


                <!-- Icon Container -->

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_notification_icon">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:contentDescription="Price Change Alerts"
                        android:src="@drawable/ic_card"
                        app:tint="#22C55E" />

                </FrameLayout>


                <!-- Text Container -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Price Change Alerts"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Alerts when subscription prices change"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                </LinearLayout>


                <!-- Switch -->

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchPriceChangeAlerts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="@color/notification_switch_thumb"
                    app:trackTint="@color/notification_switch_track" />

            </LinearLayout>


            <!-- Divider -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB" />


            <!-- ================================================= -->
            <!-- UNUSED SUBSCRIPTION ALERTS                        -->
            <!-- ================================================= -->

            <LinearLayout
                android:id="@+id/layoutUnusedSubscriptionAlerts"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">


                <!-- Icon Container -->

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_notification_icon">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:contentDescription="Unused Subscription Alerts"
                        android:src="@drawable/ic_phone"
                        app:tint="#22C55E" />

                </FrameLayout>


                <!-- Text Container -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unused Subscription Alerts"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Identify subscriptions you rarely use"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                </LinearLayout>


                <!-- Switch -->

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchUnusedSubscriptionAlerts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="@color/notification_switch_thumb"
                    app:trackTint="@color/notification_switch_track" />

            </LinearLayout>


            <!-- ================================================= -->
            <!-- LOW USAGE THRESHOLD                               -->
            <!-- ================================================= -->

            <LinearLayout
                android:id="@+id/layoutLowUsageThreshold"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="68dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:layout_weight="1"
                    android:text="Low Usage Threshold"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold" />


                <!-- Threshold Selector -->

                <TextView
                    android:id="@+id/tvLowUsageThreshold"
                    android:layout_width="150dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_budget_setting_input"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="30 days"
                    android:textColor="#111827"
                    android:textSize="14sp" />

            </LinearLayout>


            <!-- Divider -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB" />


            <!-- ================================================= -->
            <!-- AUTO-DETECT SUBSCRIPTIONS                         -->
            <!-- ================================================= -->

            <LinearLayout
                android:id="@+id/layoutAutoDetectSubscriptions"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">


                <!-- Icon Container -->

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_notification_icon">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:contentDescription="Auto Detect Subscriptions"
                        android:src="@drawable/ic_search"
                        app:tint="#22C55E" />

                </FrameLayout>


                <!-- Text Container -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Auto-Detect Subscriptions"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Detect recurring payments automatically"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                </LinearLayout>


                <!-- Switch -->

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchAutoDetectSubscriptions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="@color/notification_switch_thumb"
                    app:trackTint="@color/notification_switch_track" />

            </LinearLayout>


            <!-- Divider -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB" />


            <!-- ================================================= -->
            <!-- TRIAL ENDING ALERTS                               -->
            <!-- ================================================= -->

            <LinearLayout
                android:id="@+id/layoutTrialEndingAlerts"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">


                <!-- Icon Container -->

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_notification_icon">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:contentDescription="Trial Ending Alerts"
                        android:src="@drawable/ic_notification"
                        app:tint="#22C55E" />

                </FrameLayout>


                <!-- Text Container -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trial Ending Alerts"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Get notified before trials end"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                </LinearLayout>


                <!-- Switch -->

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchTrialEndingAlerts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="@color/notification_switch_thumb"
                    app:trackTint="@color/notification_switch_track" />

            </LinearLayout>


            <!-- Divider -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB" />


            <!-- ================================================= -->
            <!-- SUBSCRIPTION INSIGHTS                             -->
            <!-- ================================================= -->

            <LinearLayout
                android:id="@+id/layoutSubscriptionInsights"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">


                <!-- Icon Container -->

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_notification_icon">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:contentDescription="Subscription Insights"
                        android:src="@drawable/ic_insight"
                        app:tint="#22C55E" />

                </FrameLayout>


                <!-- Text Container -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Subscription Insights"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="AI-powered saving suggestions"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                </LinearLayout>


                <!-- Switch -->

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchSubscriptionInsights"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="@color/notification_switch_thumb"
                    app:trackTint="@color/notification_switch_track" />

            </LinearLayout>

        </LinearLayout>


        <!-- ===================================================== -->
        <!-- SAVE SETTINGS BUTTON                                  -->
        <!-- ===================================================== -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveSubscriptionSettings"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="20dp"
            android:text="Save Settings"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#22C55E"
            app:cornerRadius="16dp" />


        <!-- ===================================================== -->
        <!-- CANCEL BUTTON                                         -->
        <!-- ===================================================== -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelSubscriptionSettings"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:strokeColor="#D1D5DB"
            app:strokeWidth="1dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>