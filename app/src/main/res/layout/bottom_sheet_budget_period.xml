<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/budgetPeriodBottomSheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_notification_bottom_sheet"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">


        <!-- DRAG HANDLE -->

        <View
            android:layout_width="48dp"
            android:layout_height="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_bottom_sheet_handle" />


        <!-- TITLE -->

        <TextView
            android:id="@+id/tvBudgetPeriodTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Select Budget Period"
            android:textColor="#111827"
            android:textSize="22sp"
            android:textStyle="bold" />


        <!-- DESCRIPTION -->

        <TextView
            android:id="@+id/tvBudgetPeriodDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="30dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="30dp"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:text="Choose how often your budget should reset."
            android:textColor="#6B7280"
            android:textSize="14sp" />


        <!-- PERIOD OPTIONS CARD -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBudgetPeriodOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="#E5E7EB"
            app:strokeWidth="1dp">

            <RadioGroup
                android:id="@+id/radioGroupBudgetPeriod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:checkedButton="@id/radioMonthly">


                <!-- WEEKLY -->

                <LinearLayout
                    android:id="@+id/layoutWeekly"
                    android:layout_width="match_parent"
                    android:layout_height="92dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="18dp">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioWeekly"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:buttonTint="#22C55E"
                        android:clickable="false"
                        android:focusable="false" />


                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/weekly">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:contentDescription="Weekly"
                            android:src="@drawable/ic_calendar_week"
                            app:tint="#22C55E" />

                    </FrameLayout>


                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Weekly"
                            android:textColor="#111827"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Resets every week"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>


                <!-- DIVIDER -->

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E7EB" />


                <!-- MONTHLY -->

                <LinearLayout
                    android:id="@+id/layoutMonthly"
                    android:layout_width="match_parent"
                    android:layout_height="92dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="18dp">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioMonthly"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:buttonTint="#22C55E"
                        android:checked="true"
                        android:clickable="false"
                        android:focusable="false" />


                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/monthly">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:contentDescription="Monthly"
                            android:src="@drawable/ic_calendar_month"
                            app:tint="#22C55E" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Monthly"
                            android:textColor="#111827"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Resets every month"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>


                <!-- DIVIDER -->

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E7EB" />


                <!-- QUARTERLY -->

                <LinearLayout
                    android:id="@+id/layoutQuarterly"
                    android:layout_width="match_parent"
                    android:layout_height="92dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="18dp">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioQuarterly"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:buttonTint="#22C55E"
                        android:clickable="false"
                        android:focusable="false" />


                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/quarterly">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:contentDescription="Quarterly"
                            android:src="@drawable/ic_calendar_quarter"
                            app:tint="#22C55E" />

                    </FrameLayout>


                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quarterly"
                            android:textColor="#111827"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Resets every 3 months"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>


                <!-- DIVIDER -->

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E7EB" />


                <!-- YEARLY -->

                <LinearLayout
                    android:id="@+id/layoutYearly"
                    android:layout_width="match_parent"
                    android:layout_height="92dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="18dp">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioYearly"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:buttonTint="#22C55E"
                        android:clickable="false"
                        android:focusable="false" />


                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/yearly">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:contentDescription="Yearly"
                            android:src="@drawable/ic_calendar_year"
                            app:tint="#22C55E" />

                    </FrameLayout>


                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Yearly"
                            android:textColor="#111827"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Resets every year"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

            </RadioGroup>

        </com.google.android.material.card.MaterialCardView>


        <!-- APPLY PERIOD BUTTON -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApplyBudgetPeriod"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="28dp"
            android:text="Apply Period"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#22C55E"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_check_circle"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="#FFFFFF" />


        <!-- CANCEL BUTTON -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelBudgetPeriod"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:strokeColor="#D1D5DB"
            app:strokeWidth="1dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>