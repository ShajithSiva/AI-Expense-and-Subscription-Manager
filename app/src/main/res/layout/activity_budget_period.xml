<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".ui.profile.BudgetPeriodActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarBudgetPeriod"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:title="Budget Period Settings"
            android:titleTextColor="#111827"
            app:navigationIcon="@drawable/ic_back_arrow"
            app:navigationIconTint="#111827" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Current Budget Period -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="CURRENT BUDGET PERIOD"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    app:cardBackgroundColor="#F8FAFC"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="18dp">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:contentDescription="Budget period"
                            android:src="@drawable/calendar"
                            app:tint="#16A34A" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Selected period"
                                android:textColor="#6B7280"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tvCurrentBudgetPeriod"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:text="Monthly"
                                android:textColor="#111827"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Select Budget Period -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="SELECT BUDGET PERIOD"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#F8FAFC"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1dp">

                    <RadioGroup
                        android:id="@+id/radioGroupBudgetPeriod"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Weekly -->

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioWeekly"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:gravity="center_vertical"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="Weekly"
                            android:textColor="#111827"
                            android:textSize="16sp"
                            app:buttonTint="#16A34A" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="18dp"
                            android:layout_marginEnd="18dp"
                            android:background="#E5E7EB" />

                        <!-- Monthly -->

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioMonthly"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:checked="true"
                            android:gravity="center_vertical"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="Monthly"
                            android:textColor="#111827"
                            android:textSize="16sp"
                            app:buttonTint="#16A34A" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="18dp"
                            android:layout_marginEnd="18dp"
                            android:background="#E5E7EB" />

                        <!-- Quarterly -->

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioQuarterly"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:gravity="center_vertical"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="Quarterly"
                            android:textColor="#111827"
                            android:textSize="16sp"
                            app:buttonTint="#16A34A" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="18dp"
                            android:layout_marginEnd="18dp"
                            android:background="#E5E7EB" />

                        <!-- Yearly -->

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioYearly"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:gravity="center_vertical"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="Yearly"
                            android:textColor="#111827"
                            android:textSize="16sp"
                            app:buttonTint="#16A34A" />

                    </RadioGroup>

                </com.google.android.material.card.MaterialCardView>

                <!-- Explanation -->

                <TextView
                    android:id="@+id/tvBudgetPeriodDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:lineSpacingExtra="2dp"
                    android:text="Your budgets and spending summaries will be organized according to the selected period."
                    android:textColor="#6B7280"
                    android:textSize="14sp" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- Save Button -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveBudgetPeriod"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:text="Save Changes"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#16A34A"
            app:cornerRadius="14dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>