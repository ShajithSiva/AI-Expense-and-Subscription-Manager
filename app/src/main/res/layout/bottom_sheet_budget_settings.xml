<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/budgetSettingsBottomSheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_notification_bottom_sheet"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">


        <!-- ===================================================== -->
        <!-- DRAG HANDLE                                           -->
        <!-- ===================================================== -->

        <View
            android:layout_width="48dp"
            android:layout_height="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_bottom_sheet_handle" />


        <!-- ===================================================== -->
        <!-- TITLE                                                 -->
        <!-- ===================================================== -->

        <TextView
            android:id="@+id/tvBudgetSettingsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Budget Settings"
            android:textColor="#111827"
            android:textSize="22sp"
            android:textStyle="bold" />


        <!-- ===================================================== -->
        <!-- DESCRIPTION                                           -->
        <!-- ===================================================== -->

        <TextView
            android:id="@+id/tvBudgetSettingsDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="24dp"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:text="Customize how your budgets work and when you receive alerts."
            android:textColor="#6B7280"
            android:textSize="14sp" />


        <!-- ===================================================== -->
        <!-- SETTINGS CONTAINER                                    -->
        <!-- ===================================================== -->

        <LinearLayout
            android:id="@+id/budgetSettingsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">


            <!-- ================================================= -->
            <!-- MONTHLY BUDGET CYCLE                              -->
            <!-- ================================================= -->

            <LinearLayout
                android:id="@+id/layoutBudgetCycle"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">


                <!-- Icon Container -->

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/budget_cycle1">

                    <ImageView
                        android:layout_width="1dp"
                        android:layout_height="1dp"
                        android:layout_gravity="center"
                        android:contentDescription="Monthly Budget Cycle"
                        android:src="@drawable/calender"
                        app:tint="@color/nav_icon_gray" />

                </FrameLayout>


                <!-- Text Container -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monthly Budget Cycle"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Choose the day your monthly budget resets"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                </LinearLayout>


                <!-- Budget Cycle Selector -->

                <TextView
                    android:id="@+id/tvBudgetCycle"
                    android:layout_width="130dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_budget_setting_input"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="1st of every month"
                    android:textColor="#111827"
                    android:textSize="13sp" />

            </LinearLayout>


            <!-- Divider -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB" />


            <!-- ================================================= -->
            <!-- DEFAULT BUDGET AMOUNT                             -->
            <!-- ================================================= -->

            <LinearLayout
                android:id="@+id/layoutDefaultBudgetAmount"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">


                <!-- Icon Container -->


                <!-- Text Container -->

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/default_amount">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:contentDescription="Default Budget Amount"
                        app:tint="#22C55E" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Default Budget Amount"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Set your default monthly budget"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                </LinearLayout>


                <!-- Budget Amount -->

                <EditText
                    android:id="@+id/etDefaultBudgetAmount"
                    android:layout_width="130dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_budget_setting_input"
                    android:gravity="center"
                    android:hint="15000"
                    android:inputType="numberDecimal"
                    android:maxLines="1"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>


            <!-- Divider -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB" />


            <!-- ================================================= -->
            <!-- BUDGET WARNING ALERT                              -->
            <!-- ================================================= -->

            <LinearLayout
                android:id="@+id/layoutBudgetWarning"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">


                <!-- Icon Container -->

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/budget_warning1">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:contentDescription="Budget Warning Alert"
                        app:tint="#22C55E" />

                </FrameLayout>


                <!-- Text Container -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Budget Warning Alert"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Get notified when you are approaching your limit"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                </LinearLayout>


                <!-- Switch -->

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchBudgetWarning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="@color/notification_switch_thumb"
                    app:trackTint="@color/notification_switch_track" />

            </LinearLayout>


            <!-- Divider -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB" />


            <!-- ================================================= -->
            <!-- WARNING THRESHOLD                                 -->
            <!-- ================================================= -->

            <LinearLayout
                android:id="@+id/layoutWarningThreshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="130dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">


                <!-- Icon Container -->


                <!-- Threshold Content -->

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/remaining_budget">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:contentDescription="Warning Threshold"/>

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">


                    <!-- Title and Percentage -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Warning Threshold"
                            android:textColor="#111827"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvThresholdValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="80%"
                            android:textColor="#22C55E"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>


                    <!-- Description -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Set the percentage to trigger a warning alert"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />


                    <!-- Slider -->

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderWarningThreshold"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:value="80"
                        android:valueFrom="50"
                        android:valueTo="100"
                        android:stepSize="5"
                        app:haloColor="#3322C55E"
                        app:thumbColor="#22C55E" />


                    <!-- Slider Values -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="50%"
                            android:textColor="#6B7280"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="75%"
                            android:textColor="#6B7280"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:text="100%"
                            android:textColor="#6B7280"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>


            <!-- Divider -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB" />


            <!-- ================================================= -->
            <!-- OVERSPENDING ALERTS                               -->
            <!-- ================================================= -->

            <LinearLayout
                android:id="@+id/layoutOverspendingAlerts"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">


                <!-- Icon Container -->

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/overspending">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:contentDescription="Overspending Alerts"
                        app:tint="#22C55E" />

                </FrameLayout>


                <!-- Text Container -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Overspending Alerts"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Get notified when you exceed your budget"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                </LinearLayout>


                <!-- Switch -->

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchOverspendingAlerts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="@color/notification_switch_thumb"
                    app:trackTint="@color/notification_switch_track" />

            </LinearLayout>


            <!-- Divider -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB" />


            <!-- ================================================= -->
            <!-- ROLLOVER REMAINING BUDGET                         -->
            <!-- ================================================= -->

            <LinearLayout
                android:id="@+id/layoutRolloverBudget"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">


                <!-- Icon Container -->

                <FrameLayout
                    android:layout_width="47dp"
                    android:layout_height="51dp"
                    android:background="@drawable/remaining_budget">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:contentDescription="Rollover Remaining Budget"
                        app:tint="#22C55E" />

                </FrameLayout>


                <!-- Text Container -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rollover Remaining Budget"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Carry forward any unused budget to the next month"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                </LinearLayout>


                <!-- Switch -->

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchRolloverBudget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="@color/notification_switch_thumb"
                    app:trackTint="@color/notification_switch_track" />

            </LinearLayout>

        </LinearLayout>


        <!-- ===================================================== -->
        <!-- SAVE SETTINGS BUTTON                                  -->
        <!-- ===================================================== -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveBudgetSettings"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="20dp"
            android:text="Save Settings"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#22C55E"
            app:cornerRadius="16dp" />


        <!-- ===================================================== -->
        <!-- CANCEL BUTTON                                         -->
        <!-- ===================================================== -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelBudgetSettings"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:strokeColor="#D1D5DB"
            app:strokeWidth="1dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>