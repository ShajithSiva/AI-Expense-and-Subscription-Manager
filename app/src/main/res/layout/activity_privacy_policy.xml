<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">


    <!-- ========================================================= -->
    <!-- TOP APP BAR                                               -->
    <!-- ========================================================= -->

    <LinearLayout
        android:id="@+id/topAppBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:elevation="1dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="12dp"
            android:src="@drawable/ic_back_arrow"
            app:tint="#111827" />


        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Privacy Policy"
            android:textColor="#111827"
            android:textSize="20sp"
            android:textStyle="bold" />


        <Space
            android:layout_width="48dp"
            android:layout_height="48dp" />

    </LinearLayout>


    <!-- ========================================================= -->
    <!-- SCROLLABLE CONTENT                                        -->
    <!-- ========================================================= -->

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollViewPrivacyPolicy"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topAppBar">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="30dp"
            android:paddingEnd="20dp"
            android:paddingBottom="40dp">


            <!-- ================================================= -->
            <!-- PRIVACY ICON                                      -->
            <!-- ================================================= -->

            <FrameLayout
                android:layout_width="127dp"
                android:layout_height="102dp"
                android:background="@drawable/privacy">

            </FrameLayout>


            <!-- ================================================= -->
            <!-- TITLE                                             -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center"
                android:text="Your Privacy Matters"
                android:textColor="#111827"
                android:textSize="25sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- DESCRIPTION                                       -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="9dp"
                android:layout_marginEnd="22dp"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:text="ExpenseVault is designed to help you manage your finances while protecting your personal information."
                android:textColor="#64748B"
                android:textSize="14sp" />


            <!-- ================================================= -->
            <!-- LAST UPDATED                                      -->
            <!-- ================================================= -->

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_category_box"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">


                <ImageView
                    android:layout_width="19dp"
                    android:layout_height="19dp"
                    android:contentDescription="Last Updated"
                    android:src="@drawable/calendar"
                    app:tint="@color/black" />


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Last updated: July 5, 2026"
                    android:textColor="#16A34A"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>


            <!-- ================================================= -->
            <!-- PRIVACY OVERVIEW TITLE                            -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="PRIVACY OVERVIEW"
                android:textColor="#475569"
                android:textSize="13sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- PRIVACY OVERVIEW CARD                             -->
            <!-- ================================================= -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#F0FDF4"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#BBF7D0"
                app:strokeWidth="1dp">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">


                    <FrameLayout
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:background="@drawable/bg_notification_icon">


                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_gravity="center"
                            android:contentDescription="Data Control"
                            android:src="@drawable/ic_lock"
                            app:tint="#22C55E" />

                    </FrameLayout>


                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">


                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Your Data, Your Control"
                            android:textColor="#111827"
                            android:textSize="16sp"
                            android:textStyle="bold" />


                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:lineSpacingExtra="2dp"
                            android:text="We are committed to protecting your personal and financial information."
                            android:textColor="#64748B"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


            <!-- ================================================= -->
            <!-- PRIVACY POLICY TITLE                              -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="PRIVACY POLICY"
                android:textColor="#475569"
                android:textSize="13sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- PRIVACY POLICY CARD                               -->
            <!-- ================================================= -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">


                    <!-- ================================================= -->
                    <!-- SECTION 01                                       -->
                    <!-- ================================================= -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp">


                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_category_box"
                            android:gravity="center"
                            android:text="01"
                            android:textColor="#16A34A"
                            android:textSize="13sp"
                            android:textStyle="bold" />


                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">


                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Information We Collect"
                                android:textColor="#111827"
                                android:textSize="16sp"
                                android:textStyle="bold" />


                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:lineSpacingExtra="3dp"
                                android:text="We may collect account information, transaction details, subscription information, financial records and app usage data required to provide ExpenseVault features."
                                android:textColor="#64748B"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>


                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        android:background="#E5E7EB" />


                    <!-- ================================================= -->
                    <!-- SECTION 02                                       -->
                    <!-- ================================================= -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp">


                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_category_box"
                            android:gravity="center"
                            android:text="02"
                            android:textColor="#16A34A"
                            android:textSize="13sp"
                            android:textStyle="bold" />


                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">


                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="How We Use Your Data"
                                android:textColor="#111827"
                                android:textSize="16sp"
                                android:textStyle="bold" />


                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:lineSpacingExtra="3dp"
                                android:text="Your information is used to manage expenses, analyze spending patterns, detect subscriptions, provide financial insights and improve your experience."
                                android:textColor="#64748B"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>


                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        android:background="#E5E7EB" />


                    <!-- ================================================= -->
                    <!-- SECTION 03                                       -->
                    <!-- ================================================= -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp">


                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_category_box"
                            android:gravity="center"
                            android:text="03"
                            android:textColor="#16A34A"
                            android:textSize="13sp"
                            android:textStyle="bold" />


                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">


                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="AI &amp; Data Processing"
                                android:textColor="#111827"
                                android:textSize="16sp"
                                android:textStyle="bold" />


                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:lineSpacingExtra="3dp"
                                android:text="ExpenseVault may use artificial intelligence and machine learning to categorize expenses, detect recurring payments, analyze subscriptions and generate financial insights."
                                android:textColor="#64748B"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>


                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        android:background="#E5E7EB" />


                    <!-- ================================================= -->
                    <!-- SECTION 04                                       -->
                    <!-- ================================================= -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp">


                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_category_box"
                            android:gravity="center"
                            android:text="04"
                            android:textColor="#16A34A"
                            android:textSize="13sp"
                            android:textStyle="bold" />


                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">


                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Family Data &amp; Sharing"
                                android:textColor="#111827"
                                android:textSize="16sp"
                                android:textStyle="bold" />


                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:lineSpacingExtra="3dp"
                                android:text="Your personal financial information remains private unless you choose to share specific information through ExpenseVault family features."
                                android:textColor="#64748B"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>


                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        android:background="#E5E7EB" />


                    <!-- ================================================= -->
                    <!-- SECTION 05                                       -->
                    <!-- ================================================= -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp">


                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_category_box"
                            android:gravity="center"
                            android:text="05"
                            android:textColor="#16A34A"
                            android:textSize="13sp"
                            android:textStyle="bold" />


                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">


                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Data Security"
                                android:textColor="#111827"
                                android:textSize="16sp"
                                android:textStyle="bold" />


                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:lineSpacingExtra="3dp"
                                android:text="We use security features and account protection measures designed to help protect your personal and financial information."
                                android:textColor="#64748B"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>


                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        android:background="#E5E7EB" />


                    <!-- ================================================= -->
                    <!-- SECTION 06                                       -->
                    <!-- ================================================= -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp">


                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_category_box"
                            android:gravity="center"
                            android:text="06"
                            android:textColor="#16A34A"
                            android:textSize="13sp"
                            android:textStyle="bold" />


                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">


                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Your Privacy Choices"
                                android:textColor="#111827"
                                android:textSize="16sp"
                                android:textStyle="bold" />


                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:lineSpacingExtra="3dp"
                                android:text="You can review and manage certain account, notification, security and privacy preferences available within ExpenseVault."
                                android:textColor="#64748B"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


            <!-- ================================================= -->
            <!-- YOUR RIGHTS TITLE                                 -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="YOUR RIGHTS"
                android:textColor="#475569"
                android:textSize="13sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- YOUR RIGHTS CARD                                  -->
            <!-- ================================================= -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="18dp">


                    <!-- RIGHT 1 -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:background="@drawable/green_true"
                            android:gravity="center"
                            android:text="✓"
                            android:textColor="#16A34A"
                            android:textSize="16sp"
                            android:textStyle="bold" />


                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="Access your personal information"
                            android:textColor="#334155"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>


                    <!-- RIGHT 2 -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:background="@drawable/green_true"
                            android:gravity="center"
                            android:text="✓"
                            android:textColor="#16A34A"
                            android:textSize="16sp"
                            android:textStyle="bold" />


                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="Update incorrect account information"
                            android:textColor="#334155"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>


                    <!-- RIGHT 3 -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:background="@drawable/green_true"
                            android:gravity="center"
                            android:text="✓"
                            android:textColor="#16A34A"
                            android:textSize="16sp"
                            android:textStyle="bold" />


                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="Manage your privacy preferences"
                            android:textColor="#334155"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>


                    <!-- RIGHT 4 -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:background="@drawable/green_true"
                            android:gravity="center"
                            android:text="✓"
                            android:textColor="#16A34A"
                            android:textSize="16sp"
                            android:textStyle="bold" />


                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="Request account and data deletion"
                            android:textColor="#334155"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


            <!-- ================================================= -->
            <!-- PRIVACY CONTACT TITLE                             -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="QUESTIONS ABOUT YOUR PRIVACY?"
                android:textColor="#475569"
                android:textSize="13sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- CONTACT PRIVACY TEAM CARD                         -->
            <!-- ================================================= -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#F0FDF4"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#BBF7D0"
                app:strokeWidth="1dp">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="22dp"
                    android:paddingTop="26dp"
                    android:paddingEnd="22dp"
                    android:paddingBottom="24dp">


                    <FrameLayout
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:background="@drawable/contact_privacy_team">


                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:contentDescription="Privacy Team"
                            android:src="@drawable/green_true"
                            app:tint="#22C55E" />

                    </FrameLayout>


                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="Contact Privacy Team"
                        android:textColor="#111827"
                        android:textSize="19sp"
                        android:textStyle="bold" />


                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="7dp"
                        android:layout_marginEnd="16dp"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp"
                        android:text="Have questions or concerns about how your information is handled? We're here to help."
                        android:textColor="#64748B"
                        android:textSize="13sp" />


                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnContactPrivacyTeam"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="22dp"
                        android:text="Contact Privacy Team"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:backgroundTint="#22C55E"
                        app:cornerRadius="15dp"
                        app:icon="@drawable/ic_email"
                        app:iconGravity="textStart"
                        app:iconPadding="10dp"
                        app:iconTint="#FFFFFF" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


            <!-- ================================================= -->
            <!-- FOOTER                                            -->
            <!-- ================================================= -->

            <LinearLayout
