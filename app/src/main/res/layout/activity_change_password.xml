<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FA">

    <!-- ========================================================= -->
    <!-- HEADER                                                    -->
    <!-- ========================================================= -->

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="13dp"
            android:src="@drawable/ic_back_arrow"
            app:tint="#111827" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Change Password"
            android:textColor="#111827"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>


    <!-- ========================================================= -->
    <!-- HEADER DIVIDER                                            -->
    <!-- ========================================================= -->

    <View
        android:id="@+id/headerDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E5E7EB"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout" />


    <!-- ========================================================= -->
    <!-- SCROLL CONTENT                                            -->
    <!-- ========================================================= -->

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerDivider">

        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="28dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">


            <!-- ================================================= -->
            <!-- SECURITY ICON                                     -->
            <!-- ================================================= -->

            <FrameLayout
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:layout_gravity="center_horizontal">


                <!-- Outer Circle -->

                <View
                    android:layout_width="130dp"
                    android:layout_height="130dp"
                    android:background="@drawable/bg_security_circle" />


                <!-- Lock Icon Background -->

                <FrameLayout
                    android:layout_width="86dp"
                    android:layout_height="86dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_security_inner">

                    <ImageView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_gravity="center"
                        android:contentDescription="Account Security"
                        android:src="@drawable/ic_lock"
                        app:tint="#111827" />

                </FrameLayout>


                <!-- Small Green Security Badge -->

                <FrameLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_camera_circle">

                    <ImageView
                        android:layout_width="21dp"
                        android:layout_height="21dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_lock"
                        app:tint="#FFFFFF" />

                </FrameLayout>

            </FrameLayout>


            <!-- ================================================= -->
            <!-- SECURITY TITLE                                    -->
            <!-- ================================================= -->

            <TextView
                android:id="@+id/tvSecurityTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="Keep your account secure"
                android:textColor="#111827"
                android:textSize="20sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- SECURITY DESCRIPTION                              -->
            <!-- ================================================= -->

            <TextView
                android:id="@+id/tvSecurityDescription"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="Use a strong password that you don't use anywhere else."
                android:textColor="#6B7280"
                android:textSize="14sp" />


            <!-- ================================================= -->
            <!-- UPDATE PASSWORD TITLE                             -->
            <!-- ================================================= -->

            <TextView
                android:id="@+id/tvUpdatePasswordTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="UPDATE PASSWORD"
                android:textColor="#6B7280"
                android:textSize="13sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- PASSWORD CARD                                     -->
            <!-- ================================================= -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/passwordCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="#EEEEEE"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="20dp">


                    <!-- ================================================= -->
                    <!-- CURRENT PASSWORD                                  -->
                    <!-- ================================================= -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current Password"
                        android:textColor="#6B7280"
                        android:textSize="13sp"
                        android:textStyle="bold" />


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <!-- Lock Icon -->

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_field_icon">

                            <ImageView
                                android:layout_width="23dp"
                                android:layout_height="23dp"
                                android:layout_gravity="center"
                                android:contentDescription="Current Password"
                                android:src="@drawable/ic_lock"
                                app:tint="#111827" />

                        </FrameLayout>


                        <!-- Current Password Input -->

                        <EditText
                            android:id="@+id/etCurrentPassword"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Enter your current password"
                            android:imeOptions="actionNext"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:padding="0dp"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF"
                            android:textSize="15sp" />


                        <!-- Current Password Eye -->

                        <ImageButton
                            android:id="@+id/btnCurrentPasswordVisibility"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Show Current Password"
                            android:padding="10dp"
                            android:src="@drawable/ic_visibility"
                            app:tint="#111827" />

                    </LinearLayout>


                    <!-- ================================================= -->
                    <!-- FORGOT PASSWORD                                   -->
                    <!-- ================================================= -->

                    <TextView
                        android:id="@+id/tvForgotPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_gravity="end"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingEnd="4dp"
                        android:text="Forgot Password?"
                        android:textColor="#22C55E"
                        android:textSize="13sp"
                        android:textStyle="bold" />


                    <!-- Divider -->

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:background="#E5E7EB" />


                    <!-- ================================================= -->
                    <!-- NEW PASSWORD                                      -->
                    <!-- ================================================= -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="New Password"
                        android:textColor="#6B7280"
                        android:textSize="13sp"
                        android:textStyle="bold" />


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <!-- Lock Icon -->

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_field_icon">

                            <ImageView
                                android:layout_width="23dp"
                                android:layout_height="23dp"
                                android:layout_gravity="center"
                                android:contentDescription="New Password"
                                android:src="@drawable/ic_lock"
                                app:tint="#111827" />

                        </FrameLayout>


                        <!-- New Password Input -->

                        <EditText
                            android:id="@+id/etNewPassword"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Enter your new password"
                            android:imeOptions="actionNext"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:padding="0dp"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF"
                            android:textSize="15sp" />


                        <!-- New Password Eye -->

                        <ImageButton
                            android:id="@+id/btnNewPasswordVisibility"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Show New Password"
                            android:padding="10dp"
                            android:src="@drawable/ic_visibility"
                            app:tint="#111827" />

                    </LinearLayout>


                    <!-- Divider -->

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:background="#E5E7EB" />


                    <!-- ================================================= -->
                    <!-- CONFIRM PASSWORD                                  -->
                    <!-- ================================================= -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Confirm New Password"
                        android:textColor="#6B7280"
                        android:textSize="13sp"
                        android:textStyle="bold" />


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <!-- Lock Icon -->

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_field_icon">

                            <ImageView
                                android:layout_width="23dp"
                                android:layout_height="23dp"
                                android:layout_gravity="center"
                                android:contentDescription="Confirm New Password"
                                android:src="@drawable/ic_lock"
                                app:tint="#111827" />

                        </FrameLayout>


                        <!-- Confirm Password Input -->

                        <EditText
                            android:id="@+id/etConfirmPassword"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Re-enter your new password"
                            android:imeOptions="actionDone"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:padding="0dp"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF"
                            android:textSize="15sp" />


                        <!-- Confirm Password Eye -->

                        <ImageButton
                            android:id="@+id/btnConfirmPasswordVisibility"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Show Confirm Password"
                            android:padding="10dp"
                            android:src="@drawable/ic_visibility"
                            app:tint="#111827" />

                    </LinearLayout>


                    <!-- Divider -->

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:background="#E5E7EB" />


                    <!-- ================================================= -->
                    <!-- PASSWORD REQUIREMENTS                             -->
                    <!-- ================================================= -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Password must have:"
                        android:textColor="#111827"
                        android:textSize="14sp"
                        android:textStyle="bold" />


                    <!-- Requirement 1 -->

                    <TextView
                        android:id="@+id/tvRequirementLength"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="✓   At least 8 characters"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />


                    <!-- Requirement 2 -->

                    <TextView
                        android:id="@+id/tvRequirementUppercase"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="✓   One uppercase letter"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />


                    <!-- Requirement 3 -->

                    <TextView
                        android:id="@+id/tvRequirementNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="✓   One number"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />


                    <!-- Requirement 4 -->

                    <TextView
                        android:id="@+id/tvRequirementSpecialCharacter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="✓   One special character"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


            <!-- ================================================= -->
            <!-- UPDATE PASSWORD BUTTON                            -->
            <!-- ================================================= -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdatePassword"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="28dp"
                android:text="Update Password"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#22C55E"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_lock"
                app:iconGravity="textStart"
                app:iconPadding="10dp"
                app:iconTint="#FFFFFF" />


            <!-- ================================================= -->
            <!-- CANCEL BUTTON                                     -->
            <!-- ================================================= -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="12dp"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="#374151"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:strokeColor="#D1D5DB"
                app:strokeWidth="1dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>