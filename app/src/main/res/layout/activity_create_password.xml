<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".CreatePasswordActivity">


    <!-- ========================================================= -->
    <!-- BACK BUTTON                                               -->
    <!-- ========================================================= -->

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:padding="13dp"
        android:src="@drawable/ic_back_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#111827" />


    <!-- ========================================================= -->
    <!-- SCROLLABLE CONTENT                                        -->
    <!-- ========================================================= -->

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollViewCreatePassword"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="70dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">


            <!-- ================================================= -->
            <!-- LOGO                                              -->
            <!-- ================================================= -->

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="82dp"
                android:layout_height="82dp"
                android:contentDescription="ExpenseVault Logo"
                android:scaleType="centerInside"
                android:src="@drawable/logo" />


            <!-- ================================================= -->
            <!-- APP NAME                                          -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="ExpenseVault"
                android:textColor="#0F172A"
                android:textSize="23sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- APP TAGLINE                                       -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:letterSpacing="0.16"
                android:text="♢ PROTECT EVERY RUPEE"
                android:textColor="#9CA3AF"
                android:textSize="10sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- TITLE                                             -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="54dp"
                android:text="Create Your Password"
                android:textColor="#0F172A"
                android:textSize="24sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- DESCRIPTION                                       -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:lineSpacingExtra="3dp"
                android:text="Create a strong password to secure your ExpenseVault account."
                android:textColor="#6B7280"
                android:textSize="14sp" />


            <!-- ================================================= -->
            <!-- PASSWORD LABEL                                    -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="PASSWORD"
                android:textColor="#6B7280"
                android:textSize="11sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- PASSWORD INPUT                                    -->
            <!-- ================================================= -->

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/passwordInputLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxBackgroundColor="#F3F4F6"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="1dp"
                app:boxStrokeColor="#22C55E"
                app:endIconMode="password_toggle"
                app:endIconTint="#6B7280"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="#9CA3AF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@null"
                    android:hint="Enter your password"
                    android:paddingStart="45dp"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>


            <!-- ================================================= -->
            <!-- CONFIRM PASSWORD LABEL                            -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="CONFIRM PASSWORD"
                android:textColor="#6B7280"
                android:textSize="11sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- CONFIRM PASSWORD INPUT                            -->
            <!-- ================================================= -->

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/confirmPasswordInputLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxBackgroundColor="#F3F4F6"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="1dp"
                app:boxStrokeColor="#22C55E"
                app:endIconMode="password_toggle"
                app:endIconTint="#6B7280"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="#9CA3AF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@null"
                    android:hint="Re-enter your password"
                    android:imeOptions="actionDone"
                    android:paddingStart="45dp"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>


            <!-- ================================================= -->
            <!-- PASSWORD REQUIREMENTS CARD                        -->
            <!-- ================================================= -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPasswordRequirements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="#F8FAFC"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="16dp">


                    <!-- REQUIREMENTS TITLE -->

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="PASSWORD REQUIREMENTS"
                        android:textColor="#6B7280"
                        android:textSize="11sp"
                        android:textStyle="bold" />


                    <!-- REQUIREMENT 1 -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <TextView
                            android:id="@+id/checkMinCharacters"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:background="@drawable/resource_true"
                            android:gravity="center"
                            android:text="✓"
                            android:textColor="#9CA3AF"
                            android:textSize="12sp"
                            android:textStyle="bold" />


                        <TextView
                            android:id="@+id/tvMinCharacters"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="11dp"
                            android:layout_weight="1"
                            android:text="At least 8 characters"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                    </LinearLayout>


                    <!-- REQUIREMENT 2 -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="11dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <TextView
                            android:id="@+id/checkUppercase"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:background="@drawable/resource_true"
                            android:gravity="center"
                            android:text="✓"
                            android:textColor="#9CA3AF"
                            android:textSize="12sp"
                            android:textStyle="bold" />


                        <TextView
                            android:id="@+id/tvUppercase"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="11dp"
                            android:layout_weight="1"
                            android:text="One uppercase letter"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                    </LinearLayout>


                    <!-- REQUIREMENT 3 -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="11dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <TextView
                            android:id="@+id/checkLowercase"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:background="@drawable/resource_true"
                            android:gravity="center"
                            android:text="✓"
                            android:textColor="#9CA3AF"
                            android:textSize="12sp"
                            android:textStyle="bold" />


                        <TextView
                            android:id="@+id/tvLowercase"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="11dp"
                            android:layout_weight="1"
                            android:text="One lowercase letter"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                    </LinearLayout>


                    <!-- REQUIREMENT 4 -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="11dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <TextView
                            android:id="@+id/checkNumber"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:background="@drawable/resource_true"
                            android:gravity="center"
                            android:text="✓"
                            android:textColor="#9CA3AF"
                            android:textSize="12sp"
                            android:textStyle="bold" />


                        <TextView
                            android:id="@+id/tvNumber"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="11dp"
                            android:layout_weight="1"
                            android:text="One number"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                    </LinearLayout>


                    <!-- REQUIREMENT 5 -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="11dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <TextView
                            android:id="@+id/checkSpecialCharacter"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:background="@drawable/resource_true"
                            android:gravity="center"
                            android:text="✓"
                            android:textColor="#9CA3AF"
                            android:textSize="12sp"
                            android:textStyle="bold" />


                        <TextView
                            android:id="@+id/tvSpecialCharacter"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="11dp"
                            android:layout_weight="1"
                            android:text="One special character"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                    </LinearLayout>


                    <!-- PASSWORD MATCH STATUS -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="11dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <TextView
                            android:id="@+id/checkPasswordsMatch"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:background="@drawable/resource_true"
                            android:gravity="center"
                            android:text="✓"
                            android:textColor="#9CA3AF"
                            android:textSize="12sp"
                            android:textStyle="bold" />


                        <TextView
                            android:id="@+id/tvPasswordsMatch"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="11dp"
                            android:layout_weight="1"
                            android:text="Both passwords match"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


            <!-- ================================================= -->
            <!-- CREATE ACCOUNT BUTTON                             -->
            <!-- ================================================= -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateAccount"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="24dp"
                android:text="Create Account   →"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#22C55E"
                app:cornerRadius="14dp" />


            <!-- ================================================= -->
            <!-- SECURITY MESSAGE                                  -->
            <!-- ================================================= -->

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="17dp"
                android:gravity="center"
                android:orientation="horizontal">


                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="Security"
                    android:src="@drawable/ic_lock"
                    app:tint="#22C55E" />


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:text="Your password is securely protected"
                    android:textColor="#6B7280"
                    android:textSize="11sp" />

            </LinearLayout>


            <!-- ================================================= -->
            <!-- STEP INDICATOR                                    -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Step 3 of 3"
                android:textColor="#22C55E"
                android:textSize="10sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- FOOTER                                            -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:letterSpacing="0.08"
                android:text="SECURED BY EXPENSEVAULT"
                android:textColor="#C4C7CC"
                android:textSize="9sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>