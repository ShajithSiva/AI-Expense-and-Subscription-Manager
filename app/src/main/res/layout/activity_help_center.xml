<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">


    <!-- ========================================================= -->
    <!-- TOP APP BAR                                               -->
    <!-- ========================================================= -->

    <LinearLayout
        android:id="@+id/topAppBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:elevation="1dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="12dp"
            android:src="@drawable/ic_back_arrow"
            app:tint="#111827" />


        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Help Center"
            android:textColor="#111827"
            android:textSize="20sp"
            android:textStyle="bold" />


        <Space
            android:layout_width="48dp"
            android:layout_height="48dp" />

    </LinearLayout>


    <!-- ========================================================= -->
    <!-- SCROLLABLE CONTENT                                        -->
    <!-- ========================================================= -->

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollViewHelpCenter"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topAppBar">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="28dp"
            android:paddingEnd="20dp"
            android:paddingBottom="40dp">


            <!-- ================================================= -->
            <!-- INTRODUCTION                                      -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="How can we help you?"
                android:textColor="#111827"
                android:textSize="25sp"
                android:textStyle="bold" />


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="24dp"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="Find answers, explore helpful guides, or contact our support team."
                android:textColor="#64748B"
                android:textSize="14sp" />


            <!-- ================================================= -->
            <!-- SEARCH BAR                                        -->
            <!-- ================================================= -->

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/searchInputLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:boxBackgroundColor="#FFFFFF"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="#E2E8F0"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:startIconDrawable="@drawable/ic_search"
                app:startIconTint="#64748B">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSearchHelp"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:hint="Search Help Center"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="#111827"
                    android:textColorHint="#94A3B8"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>


            <!-- ================================================= -->
            <!-- QUICK HELP                                        -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="QUICK HELP"
                android:textColor="#475569"
                android:textSize="13sp"
                android:textStyle="bold" />


            <!-- FIRST QUICK HELP ROW -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:baselineAligned="false"
                android:orientation="horizontal">


                <!-- EXPENSES -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHelpExpenses"
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="14dp">


                        <FrameLayout
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:background="@drawable/expense1">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:contentDescription="Expenses"
                                android:src="@drawable/ic_expenses"
                                app:tint="#22C55E" />

                        </FrameLayout>


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Expenses"
                            android:textColor="#111827"
                            android:textSize="15sp"
                            android:textStyle="bold" />


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:text="Track &amp; edit expenses"
                            android:textColor="#64748B"
                            android:textSize="11sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>


                <!-- BUDGETS -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHelpBudgets"
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="14dp">


                        <FrameLayout
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:background="@drawable/budget1">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:contentDescription="Budgets"
                                android:src="@drawable/ic_budget"
                                app:tint="#22C55E" />

                        </FrameLayout>


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Budgets"
                            android:textColor="#111827"
                            android:textSize="15sp"
                            android:textStyle="bold" />


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:text="Manage spending limits"
                            android:textColor="#64748B"
                            android:textSize="11sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>


            <!-- SECOND QUICK HELP ROW -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:baselineAligned="false"
                android:orientation="horizontal">


                <!-- SUBSCRIPTIONS -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHelpSubscriptions"
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="14dp">


                        <FrameLayout
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:background="@drawable/subs1">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:contentDescription="Subscriptions"
                                android:src="@drawable/ic_subscription"
                                app:tint="#22C55E" />

                        </FrameLayout>


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Subscriptions"
                            android:textColor="#111827"
                            android:textSize="15sp"
                            android:textStyle="bold" />


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:text="Manage recurring plans"
                            android:textColor="#64748B"
                            android:textSize="11sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>


                <!-- FAMILY -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHelpFamily"
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="14dp">


                        <FrameLayout
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:background="@drawable/fam">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:contentDescription="Family"
                                android:src="@drawable/ic_family"
                                app:tint="#22C55E" />

                        </FrameLayout>


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Family"
                            android:textColor="#111827"
                            android:textSize="15sp"
                            android:textStyle="bold" />


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:text="Shared family finance"
                            android:textColor="#64748B"
                            android:textSize="11sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>


            <!-- ================================================= -->
            <!-- FAQ TITLE                                         -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="FREQUENTLY ASKED QUESTIONS"
                android:textColor="#475569"
                android:textSize="13sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- FAQ CARD                                          -->
            <!-- ================================================= -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">


                    <!-- FAQ 1 -->

                    <LinearLayout
                        android:id="@+id/faqAddExpense"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="How do I add an expense?"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="48dp"
                            android:gravity="center"
                            android:text="›"
                            android:textColor="#64748B"
                            android:textSize="27sp" />

                    </LinearLayout>


                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="18dp"
                        android:background="#E5E7EB" />


                    <!-- FAQ 2 -->

                    <LinearLayout
                        android:id="@+id/faqAiCategorization"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="How does AI categorization work?"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="48dp"
                            android:gravity="center"
                            android:text="›"
                            android:textColor="#64748B"
                            android:textSize="27sp" />

                    </LinearLayout>


                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="18dp"
                        android:background="#E5E7EB" />


                    <!-- FAQ 3 -->

                    <LinearLayout
                        android:id="@+id/faqManageBudget"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="How do I manage my budget?"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="48dp"
                            android:gravity="center"
                            android:text="›"
                            android:textColor="#64748B"
                            android:textSize="27sp" />

                    </LinearLayout>


                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="18dp"
                        android:background="#E5E7EB" />


                    <!-- FAQ 4 -->

                    <LinearLayout
                        android:id="@+id/faqSubscriptions"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="How do I manage subscriptions?"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="48dp"
                            android:gravity="center"
                            android:text="›"
                            android:textColor="#64748B"
                            android:textSize="27sp" />

                    </LinearLayout>


                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="18dp"
                        android:background="#E5E7EB" />


                    <!-- FAQ 5 -->

                    <LinearLayout
                        android:id="@+id/faqDataSecurity"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Is my financial data secure?"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="48dp"
                            android:gravity="center"
                            android:text="›"
                            android:textColor="#64748B"
                            android:textSize="27sp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


            <!-- ================================================= -->
            <!-- CONTACT SUPPORT TITLE                             -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="STILL NEED HELP?"
                android:textColor="#475569"
                android:textSize="13sp"
                android:textStyle="bold" />


            <!-- ================================================= -->
            <!-- CONTACT SUPPORT CARD                              -->
            <!-- ================================================= -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#F0FDF4"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#BBF7D0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="22dp"
                    android:paddingTop="26dp"
                    android:paddingEnd="22dp"
                    android:paddingBottom="24dp">


                    <FrameLayout
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:background="@drawable/condact_support">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:contentDescription="Contact Support"
                            android:src="@drawable/ic_support"
                            app:tint="#22C55E" />

                    </FrameLayout>


                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="Contact Support"
                        android:textColor="#111827"
                        android:textSize="19sp"
                        android:textStyle="bold" />


                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="7dp"
                        android:layout_marginEnd="16dp"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp"
                        android:text="Can't find the answer you're looking for? Our support team is ready to help."
                        android:textColor="#64748B"
                        android:textSize="13sp" />


                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnContactSupport"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="22dp"
                        android:text="Contact Support"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:backgroundTint="#22C55E"
                        app:cornerRadius="15dp"
                        app:icon="@drawable/ic_email"
                        app:iconGravity="textStart"
                        app:iconPadding="10dp"
                        app:iconTint="#FFFFFF" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


            <!-- ================================================= -->
            <!-- FOOTER                                            -->
            <!-- ================================================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:gravity="center"
                android:orientation="vertical">


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EXPENSEVAULT SUPPORT"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"
                    android:textStyle="bold" />


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="Help Center • Version 1.0.0"
                    android:textColor="#CBD5E1"
                    android:textSize="10sp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>