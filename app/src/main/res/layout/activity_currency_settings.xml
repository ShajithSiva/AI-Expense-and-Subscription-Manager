<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".ui.profile.CurrencySettingsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarCurrency"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:title="Currency Settings"
            android:titleTextColor="#111827"
            app:navigationIcon="@drawable/ic_back_arrow"
            app:navigationIconTint="#111827" />

        <!-- Current Currency -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCurrentCurrency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="#F8FAFC"
            app:cardCornerRadius="16dp"
            app:cardElevation="1dp"
            app:strokeColor="#E5E7EB"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:contentDescription="Currency"
                    android:padding="5dp"
                    android:src="@drawable/currency"
                    app:tint="#16A34A" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current Currency"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvCurrentCurrencyName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Sri Lankan Rupee"
                        android:textColor="#111827"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCurrentCurrencyCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="LKR"
                        android:textColor="#6B7280"
                        android:textSize="14sp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvCurrentCurrencySymbol"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₨"
                    android:textColor="#16A34A"
                    android:textSize="21sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Search Field -->

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputLayoutSearchCurrency"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:hint="Search currency"
            app:boxBackgroundColor="#F8FAFC"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusTopStart="14dp"
            app:boxStrokeColor="#16A34A"
            app:startIconDrawable="@drawable/ic_search"
            app:startIconTint="#6B7280">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearchCurrency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="#111827"
                android:textSize="15sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Section Title -->

        <TextView
            android:id="@+id/tvAvailableCurrenciesTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="6dp"
            android:text="AVAILABLE CURRENCIES"
            android:textColor="#6B7280"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Currency List -->

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewCurrencies"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            android:scrollbars="vertical"
            tools:listitem="@layout/item_currency" />

        <!-- Error Section -->

        <LinearLayout
            android:id="@+id/layoutCurrencyError"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvCurrencyError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Unable to load currencies."
                android:textColor="#6B7280"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetryCurrencies"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Retry"
                android:textAllCaps="false"
                app:strokeColor="#16A34A" />

        </LinearLayout>

        <!-- Save Button -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveCurrency"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:text="Save Changes"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#16A34A"
            app:cornerRadius="14dp" />

    </LinearLayout>

    <!-- API Loading -->

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressCurrency"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_gravity="center"
        android:visibility="gone"
        app:indicatorColor="#16A34A"
        app:trackColor="#DCFCE7" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>