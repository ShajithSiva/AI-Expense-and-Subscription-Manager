<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/twoFactorSuccessBottomSheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_notification_bottom_sheet"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">


        <!-- DRAG HANDLE -->

        <View
            android:layout_width="48dp"
            android:layout_height="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_bottom_sheet_handle" />


        <!-- SUCCESS ICON -->

        <FrameLayout
            android:layout_width="112dp"
            android:layout_height="112dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/two_factor_verify">

        </FrameLayout>


        <!-- TITLE -->

        <TextView
            android:id="@+id/tvTwoFactorSuccessTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Two-Factor Authentication Enabled"
            android:textColor="#111827"
            android:textSize="24sp"
            android:textStyle="bold" />


        <!-- DESCRIPTION -->

        <TextView
            android:id="@+id/tvTwoFactorSuccessDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="22dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="22dp"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:text="Your account is now protected with an additional layer of security."
            android:textColor="#6B7280"
            android:textSize="14sp" />


        <!-- VERIFICATION METHOD CARD -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardVerificationMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="#E5E7EB"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">


                <!-- METHOD ICON -->

                <FrameLayout
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:background="@drawable/mail_verify">

                    <ImageView
                        android:id="@+id/ivTwoFactorMethod"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center"
                        android:contentDescription="Verification Method"
                        app:tint="#22C55E" />

                </FrameLayout>


                <!-- METHOD INFORMATION -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VERIFICATION METHOD"
                        android:textColor="#6B7280"
                        android:textSize="11sp"
                        android:textStyle="bold" />


                    <TextView
                        android:id="@+id/tvTwoFactorMethod"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Email Verification"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />


                    <TextView
                        android:id="@+id/tvTwoFactorDestination"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="alex••••@example.com"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                </LinearLayout>


                <!-- SUCCESS CHECK -->

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:contentDescription="Enabled"
                    app:tint="#22C55E" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- ACCOUNT PROTECTION CARD -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAccountProtected"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#F0FDF4"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="#BBF7D0"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:orientation="horizontal"
                android:padding="18dp">


                <!-- SHIELD ICON -->

                <FrameLayout
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:background="@drawable/protect">

                    <ImageView
                        android:layout_width="29dp"
                        android:layout_height="29dp"
                        android:layout_gravity="center"
                        android:contentDescription="Account Protected"
                        app:tint="#22C55E" />

                </FrameLayout>


                <!-- PROTECTION INFORMATION -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">


                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Your Account Is Protected"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold" />


                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:lineSpacingExtra="2dp"
                        android:text="Two-factor authentication will be required the next time you sign in."
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- SECURITY STATUS -->

        <LinearLayout
            android:id="@+id/layoutSecurityStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="horizontal">


            <View
                android:layout_width="8dp"
                android:layout_height="8dp"/>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Two-Factor Authentication is active"
                android:textColor="#16A34A"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>


        <!-- DONE BUTTON -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDoneTwoFactor"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="30dp"
            android:text="Done"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#22C55E"
            app:cornerRadius="16dp"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="#FFFFFF" />

        <ImageView
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_gravity="center"
            android:contentDescription="Two-Factor Authentication Enabled"
            android:src="@drawable/bg_category_box"
            app:tint="@color/white" />

        <FrameLayout
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:layout_gravity="center">

        </FrameLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>