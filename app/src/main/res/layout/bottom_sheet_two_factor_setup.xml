<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/twoFactorSetupBottomSheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_notification_bottom_sheet"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">


        <!-- ===================================================== -->
        <!-- DRAG HANDLE                                           -->
        <!-- ===================================================== -->

        <View
            android:layout_width="48dp"
            android:layout_height="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_bottom_sheet_handle" />


        <!-- ===================================================== -->
        <!-- TITLE                                                 -->
        <!-- ===================================================== -->

        <TextView
            android:id="@+id/tvTwoFactorTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Set Up Two-Factor Authentication"
            android:textColor="#111827"
            android:textSize="22sp"
            android:textStyle="bold" />


        <!-- ===================================================== -->
        <!-- DESCRIPTION                                           -->
        <!-- ===================================================== -->

        <TextView
            android:id="@+id/tvTwoFactorDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="32dp"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:text="Add an extra layer of security to protect your account."
            android:textColor="#6B7280"
            android:textSize="14sp" />


        <!-- ===================================================== -->
        <!-- VERIFICATION METHOD TITLE                             -->
        <!-- ===================================================== -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="VERIFICATION METHOD"
            android:textColor="#16A34A"
            android:textSize="13sp"
            android:textStyle="bold" />


        <!-- ===================================================== -->
        <!-- VERIFICATION OPTIONS CARD                             -->
        <!-- ===================================================== -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardVerificationMethods"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="#E5E7EB"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">


                <!-- ================================================= -->
                <!-- SMS VERIFICATION                                  -->
                <!-- ================================================= -->

                <LinearLayout
                    android:id="@+id/layoutSmsVerification"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="18dp">


                    <!-- Radio Button -->

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioSmsVerification"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:buttonTint="#22C55E"
                        android:checked="true"
                        android:clickable="false"
                        android:focusable="false" />


                    <!-- Icon Background -->

                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_notification_icon">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:contentDescription="SMS Verification"
                            android:src="@drawable/ic_sms_verification"
                            app:tint="#22C55E" />

                    </FrameLayout>


                    <!-- Text -->

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SMS Verification"
                            android:textColor="#111827"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:lineSpacingExtra="2dp"
                            android:text="Send verification codes to your mobile number"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>


                <!-- DIVIDER -->

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:background="#E5E7EB" />


                <!-- ================================================= -->
                <!-- EMAIL VERIFICATION                                -->
                <!-- ================================================= -->

                <LinearLayout
                    android:id="@+id/layoutEmailVerification"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="18dp">


                    <!-- Radio Button -->

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioEmailVerification"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:buttonTint="#22C55E"
                        android:clickable="false"
                        android:focusable="false" />


                    <!-- Icon Background -->

                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_notification_icon">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:contentDescription="Email Verification"
                            android:src="@drawable/ic_email"
                            app:tint="#22C55E" />

                    </FrameLayout>


                    <!-- Text -->

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Email Verification"
                            android:textColor="#111827"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:lineSpacingExtra="2dp"
                            android:text="Send verification codes to your email address"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- ===================================================== -->
        <!-- HOW 2FA WORKS CARD                                    -->
        <!-- ===================================================== -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHowTwoFactorWorks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#F0FDF4"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="#DCFCE7"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingTop="20dp"
                android:paddingEnd="18dp"
                android:paddingBottom="20dp">


                <!-- SECURITY ICON -->

                <FrameLayout
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bg_notification_icon">

                    <ImageView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_gravity="center"
                        android:contentDescription="Two Factor Security"
                        android:src="@drawable/ic_security_shield"
                        app:tint="#22C55E" />

                </FrameLayout>


                <!-- STEPS CONTAINER -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:orientation="vertical">


                    <!-- CARD TITLE -->

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="How Two-Factor Authentication Works"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold" />


                    <!-- STEP 1 -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_two_factor_step"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="#16A34A"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Enter your password"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                    </LinearLayout>


                    <!-- STEP 2 -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_two_factor_step"
                            android:gravity="center"
                            android:text="2"
                            android:textColor="#16A34A"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Receive a security code"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                    </LinearLayout>


                    <!-- STEP 3 -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_two_factor_step"
                            android:gravity="center"
                            android:text="3"
                            android:textColor="#16A34A"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Enter the code to login"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- ===================================================== -->
        <!-- CONTINUE BUTTON                                       -->
        <!-- ===================================================== -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinueTwoFactor"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="28dp"
            android:text="Continue"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#22C55E"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_arrow_forward_circle"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="#FFFFFF" />


        <!-- ===================================================== -->
        <!-- CANCEL BUTTON                                         -->
        <!-- ===================================================== -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelTwoFactor"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:strokeColor="#D1D5DB"
            app:strokeWidth="1dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>