<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Budget Management"
            app:navigationIcon="@drawable/ic_back_arrow" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Monthly Budget Summary -->

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Monthly Budget Summary"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:layout_marginBottom="16dp"/>

                        <TextView
                            android:id="@+id/tvMonthlyBudget"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Budget : Rs. 0.00"
                            android:textSize="16sp"/>

                        <TextView
                            android:id="@+id/tvSpentAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Spent : Rs. 0.00"
                            android:textSize="16sp"/>

                        <TextView
                            android:id="@+id/tvRemainingAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Remaining : Rs. 0.00"
                            android:textSize="16sp"/>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressBudget"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:max="100"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Budget Inputs -->

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Category Budgets"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:layout_marginBottom="16dp"/>

                        <!-- Monthly Budget -->

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Monthly Budget">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMonthlyBudget"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Food -->

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilFoodBudget"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Food Budget">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etFoodBudget"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Transport -->

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilTransportBudget"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Transport Budget">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etTransportBudget"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Shopping -->

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilShoppingBudget"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Shopping Budget">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etShoppingBudget"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Bills -->

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilBillsBudget"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Bills Budget">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etBillsBudget"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Health -->

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilHealthBudget"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Health Budget">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etHealthBudget"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Education -->

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilEducationBudget"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Education Budget">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etEducationBudget"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Entertainment -->

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilEntertainmentBudget"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Entertainment Budget">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etEntertainmentBudget"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Others -->

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilOthersBudget"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Others Budget">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etOthersBudget"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"/>

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Save Button -->

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveBudget"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Save Budget"/>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!-- Loading -->

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressIndicator"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:visibility="gone"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>