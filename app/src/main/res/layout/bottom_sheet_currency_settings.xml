<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/currencySettingsBottomSheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_notification_bottom_sheet"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">


        <!-- ===================================================== -->
        <!-- DRAG HANDLE                                           -->
        <!-- ===================================================== -->

        <View
            android:layout_width="48dp"
            android:layout_height="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_bottom_sheet_handle" />


        <!-- ===================================================== -->
        <!-- TITLE                                                 -->
        <!-- ===================================================== -->

        <TextView
            android:id="@+id/tvCurrencySettingsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Currency Settings"
            android:textColor="#111827"
            android:textSize="22sp"
            android:textStyle="bold" />


        <!-- ===================================================== -->
        <!-- DESCRIPTION                                           -->
        <!-- ===================================================== -->

        <TextView
            android:id="@+id/tvCurrencySettingsDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="24dp"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:text="Choose how currencies and monetary values are displayed throughout the app."
            android:textColor="#6B7280"
            android:textSize="14sp" />


        <!-- ===================================================== -->
        <!-- SETTINGS CONTAINER                                    -->
        <!-- ===================================================== -->

        <LinearLayout
            android:id="@+id/currencySettingsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:orientation="vertical">


            <!-- ================================================= -->
            <!-- PRIMARY CURRENCY                                  -->
            <!-- ================================================= -->

            <LinearLayout
                android:id="@+id/layoutPrimaryCurrency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="110dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">


                <!-- Icon Container -->

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/currency">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:contentDescription="Primary Currency"
                        app:tint="#22C55E" />

                </FrameLayout>


                <!-- Text Container -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Primary Currency"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:lineSpacingExtra="2dp"
                        android:text="The default currency used for budgets, expenses and reports"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                </LinearLayout>


                <!-- Currency Selector -->

                <LinearLayout
                    android:id="@+id/btnPrimaryCurrency"
                    android:layout_width="170dp"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_budget_setting_input"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="12dp">


                    <!-- Currency Symbol -->

                    <TextView
                        android:id="@+id/tvCurrencySymbol"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rs"
                        android:textColor="#22C55E"
                        android:textSize="15sp"
                        android:textStyle="bold" />


                    <!-- Currency Name -->

                    <TextView
                        android:id="@+id/tvPrimaryCurrency"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="LKR"
                        android:textColor="#111827"
                        android:textSize="14sp"
                        android:textStyle="bold" />


                    <!-- Arrow -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▼"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>


            <!-- ================================================= -->
            <!-- DIVIDER                                           -->
            <!-- ================================================= -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB" />


            <!-- ================================================= -->
            <!-- NUMBER FORMAT                                     -->
            <!-- ================================================= -->

            <LinearLayout
                android:id="@+id/layoutNumberFormat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="110dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">


                <!-- Icon Container -->

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_notification_icon">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="1.0"
                        android:textColor="#22C55E"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                </FrameLayout>


                <!-- Text Container -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Number Format"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:lineSpacingExtra="2dp"
                        android:text="Choose how monetary values are displayed"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                </LinearLayout>


                <!-- Number Format Selector -->

                <LinearLayout
                    android:id="@+id/btnNumberFormat"
                    android:layout_width="140dp"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_budget_setting_input"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp">


                    <!-- Selected Number Format -->

                    <TextView
                        android:id="@+id/tvNumberFormat"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="1,000.00"
                        android:textColor="#111827"
                        android:textSize="14sp"
                        android:textStyle="bold" />


                    <!-- Arrow -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▼"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>


        <!-- ===================================================== -->
        <!-- SPACER                                                -->
        <!-- ===================================================== -->

        <Space
            android:layout_width="match_parent"
            android:layout_height="100dp" />


        <!-- ===================================================== -->
        <!-- SAVE SETTINGS BUTTON                                  -->
        <!-- ===================================================== -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveCurrencySettings"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="Save Settings"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#22C55E"
            app:cornerRadius="16dp" />


        <!-- ===================================================== -->
        <!-- CANCEL BUTTON                                         -->
        <!-- ===================================================== -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelCurrencySettings"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:strokeColor="#D1D5DB"
            app:strokeWidth="1dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>