<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6F8">

    <!-- ════════════════════════════════════════
         HEADER — Back + Title + Menu
         ════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back arrow -->
        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:layout_marginEnd="4dp"/>

        <!-- Title -->
        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Member Profile"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#111827"/>

        <!-- Three-dot menu -->
        <ImageView
            android:id="@+id/ivMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"/>
    </LinearLayout>

    <!-- Thin divider under header -->
    <View
        android:id="@+id/headerDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E5E7EB"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ════════════════════════════════════════
         SCROLLABLE CONTENT
         ════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/headerDivider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ════════════════════════════════
                 1. PROFILE HERO SECTION
                    White card with avatar, name,
                    email, role badge, join date
                 ════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#FFFFFF"
                android:paddingTop="28dp"
                android:paddingBottom="24dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <!-- Avatar with online dot -->
                <FrameLayout
                    android:layout_width="88dp"
                    android:layout_height="88dp">

                    <!-- Avatar circle -->
                    <ImageView
                        android:id="@+id/ivMemberAvatar"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:src="@drawable/profile"
                        android:padding="18dp" />

                    <!-- Online / active indicator dot -->
                    <View
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="2dp"
                        android:layout_marginBottom="2dp"/>
                </FrameLayout>

                <!-- Member Name -->
                <TextView
                    android:id="@+id/tvMemberName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Arjun Sharma"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_marginTop="14dp"/>

                <!-- Email -->
                <TextView
                    android:id="@+id/tvMemberEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="arjun.sharma@family.com"
                    android:textSize="13sp"
                    android:textColor="#6B7280"
                    android:layout_marginTop="4dp"/>

                <!-- Role + Joined row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <!-- Role pill -->
                    <TextView
                        android:id="@+id/tvMemberRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Family Member"
                        android:textSize="12sp"
                        android:textColor="#374151"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="5dp"/>

                    <!-- Dot separator -->
                    <View
                        android:layout_width="4dp"
                        android:layout_height="4dp"
                        android:layout_marginHorizontal="10dp"/>

                    <!-- Joined date -->
                    <TextView
                        android:id="@+id/tvJoinedDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Joined May 2023"
                        android:textSize="12sp"
                        android:textColor="#6B7280"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ════════════════════════════════
                 2. ACTIVITY OVERVIEW CARD
                 ════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:layout_marginTop="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="20dp">

                <!-- Section header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Activity Overview"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#111827"/>

                    <!-- Clock icon -->
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        app:tint="#000000"/>

                </LinearLayout>

                <!-- Stats row: Contributed | Active Subs | Last Active -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- Contributed -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/expense"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvContributed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rs 12.4k"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#111827"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CONTRIBUTED"
                            android:textSize="9sp"
                            android:textColor="#9CA3AF"
                            android:letterSpacing="0.06"
                            android:layout_marginTop="3dp"/>
                    </LinearLayout>

                    <!-- Vertical divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="56dp"
                        android:background="#E5E7EB"
                        android:layout_gravity="center_vertical"/>

                    <!-- Active Subs -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvActiveSubs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="04"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#111827"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ACTIVE SUBS"
                            android:textSize="9sp"
                            android:textColor="#9CA3AF"
                            android:letterSpacing="0.06"
                            android:layout_marginTop="3dp"/>
                    </LinearLayout>

                    <!-- Vertical divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="56dp"
                        android:background="#E5E7EB"
                        android:layout_gravity="center_vertical"/>

                    <!-- Last Active -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvLastActive"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Today"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#111827"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LAST ACTIVE"
                            android:textSize="9sp"
                            android:textColor="#9CA3AF"
                            android:letterSpacing="0.06"
                            android:layout_marginTop="3dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ════════════════════════════════
                 3. RECENT SHARED EXPENSES
                 ════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:layout_marginTop="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp">

                <!-- Section header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Recent Shared Expenses"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#111827"/>

                    <TextView
                        android:id="@+id/tvViewAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All"
                        android:textSize="12sp"
                        android:textColor="#6B7280"/>
                </LinearLayout>

                <!-- Expense Row 1: BigBasket -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="14dp">

                    <!-- Icon box -->
                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/home"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BigBasket Grocery"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#111827"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Oct 24 · Household"
                            android:textSize="12sp"
                            android:textColor="#9CA3AF"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rs 2,450"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#111827"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3F4F6"
                    android:layout_marginStart="52dp"/>

                <!-- Expense Row 2: Blue Tokai -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="14dp">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/coffee"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Blue Tokai Coffee"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#111827"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Oct 22 · Dining"
                            android:textSize="12sp"
                            android:textColor="#9CA3AF"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rs 680"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#111827"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3F4F6"
                    android:layout_marginStart="52dp"/>

                <!-- Expense Row 3: Tata Power Bill -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="14dp">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/current_bill"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tata Power Bill"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#111827"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Oct 18 · Utilities"
                            android:textSize="12sp"
                            android:textColor="#9CA3AF"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rs 4,120"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#111827"/>
                </LinearLayout>

            </LinearLayout>

            <!-- ════════════════════════════════
                 4. ROLE MANAGEMENT
                 ════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:layout_marginTop="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Role Management"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_marginBottom="12dp"/>

                <!-- Role card row -->
                <LinearLayout
                    android:id="@+id/btnChangeRole"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <!-- Person icon box -->
                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/profile"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Current Role"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#111827"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Permissions: Limited viewing &amp; spending"
                            android:textSize="12sp"
                            android:textColor="#6B7280"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <!-- Member → badge + arrow -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Member"
                            android:textSize="12sp"
                            android:textColor="#374151"/>

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_arrow_right"
                            android:layout_marginStart="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ════════════════════════════════
                 5. REMOVE FROM FAMILY BUTTON
                 ════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:padding="16dp">

                <LinearLayout
                    android:id="@+id/btnRemoveFromFamily"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Remove from Family"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#EF4444"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>